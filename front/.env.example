# Frontend API base URL (recommended)
# Example:
# VUE_APP_API_BASE_URL=http://192.168.0.100:8001
#
# Notes:
# 1) front/utils/request.js reads env in this order:
#    VUE_APP_API_BASE_URL -> UNI_APP_API_BASE_URL -> API_BASE_URL
# 2) Runtime override via storage key "__API_BASE_URL__" still takes highest priority.
# 3) If none is set, request.js falls back to localhost:8001.
# 4) WeChat DevTools on the same PC can use 127.0.0.1:8001.
# 5) Real-device debugging on the same Wi-Fi should use your computer's LAN IP, for example 192.168.x.x:8001.
VUE_APP_API_BASE_URL=http://127.0.0.1:8001

# Tencent Map key for reverse geocoding (city detection on "人脉库")
# Fill one of these keys if you use env injection in your build chain:
# UNI_APP_QQ_MAP_KEY=your_qq_map_key
# VUE_APP_QQ_MAP_KEY=your_qq_map_key
UNI_APP_QQ_MAP_KEY=your_qq_map_key
