# Frontend API base URL (recommended)
# Put local/LAN API address in .env.development
# Put public API address in .env.production
#
# Notes:
# 1) front/utils/request.js reads env in this order:
#    VUE_APP_API_BASE_URL -> UNI_APP_API_BASE_URL -> API_BASE_URL
# 2) Runtime override via storage key "__API_BASE_URL__" is only used in development.
# 3) Production no longer reads runtime override, to avoid local/debug settings leaking online.
# 4) If env is unknown, request.js falls back to the development address instead of silently routing to production.
# 5) WeChat DevTools on the same PC can use 127.0.0.1 or your LAN IP.
VUE_APP_API_BASE_URL=http://127.0.0.1:8001

# Tencent Map key for reverse geocoding (city detection on "人脉库")
# Fill one of these keys if you use env injection in your build chain:
# UNI_APP_QQ_MAP_KEY=your_qq_map_key
# VUE_APP_QQ_MAP_KEY=your_qq_map_key
UNI_APP_QQ_MAP_KEY=your_qq_map_key
